{
  "name": "pflegelotse",
  "version": "0.1.0",
  "description": "PflegeLotse — Tourenoptimierung für ambulante Pflegedienste",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "next dev",
    "devsafe": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "osrm:prepare": "bash infra/osrm/prepare.sh",
    "osrm:up": "docker compose -f infra/osrm/docker-compose.yml up -d",
    "osrm:down": "docker compose -f infra/osrm/docker-compose.yml down",
    "osrm:up:prod": "docker compose -f infra/osrm/docker-compose.prod.yml up -d",
    "osrm:down:prod": "docker compose -f infra/osrm/docker-compose.prod.yml down",
    "db:up": "docker compose up -d mongo && node scripts/wait-for-mongo.mjs",
    "db:down": "docker compose down",
    "db:init": "node --env-file=.env --import tsx scripts/db-init.ts",
    "db:seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "admin:create": "node --env-file=.env --import tsx scripts/create-admin.ts",
    "user:tenant": "node --env-file=.env --import tsx scripts/set-tenant.ts",
    "check:encryption": "node --env-file=.env --import tsx scripts/check-encryption.ts",
    "generate:types": "payload generate:types",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@payloadcms/db-mongodb": "^3.37.0",
    "@payloadcms/next": "^3.37.0",
    "@payloadcms/richtext-lexical": "^3.37.0",
    "@payloadcms/translations": "^3.37.0",
    "@sentry/nextjs": "^10.60.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "graphql": "^16.9.0",
    "maplibre-gl": "^4.7.1",
    "mongodb-client-encryption": "^6.5.0",
    "next": "15.3.9",
    "next-intl": "^3.26.3",
    "payload": "^3.37.0",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.3.9",
    "mongodb": "^6.12.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "22.x"
  }
}
