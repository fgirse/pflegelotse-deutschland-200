# Wird von infra/osrm/docker-compose.yml gelesen. prepare.sh setzt OSRM_DATA
# automatisch auf den Basisnamen des verarbeiteten Extrakts.
# Beispiele: germany-latest | baden-wuerttemberg-latest
OSRM_DATA=germany-latest

# Nur für den produktiven Betrieb (docker-compose.prod.yml):
# Öffentliche Domain (DNS-A-Record zeigt auf diesen Host).
OSRM_DOMAIN=osrm.example.com
# Langes Zufalls-Secret. Erzeugen: openssl rand -hex 32
# Muss identisch in den App-Env-Variablen als OSRM_API_KEY stehen.
OSRM_API_KEY=
