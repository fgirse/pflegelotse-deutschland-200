# MongoDB-Verbindung. Standard: MongoDB Atlas (Cloud, EU-Region).
# Atlas ist bereits ein Replica-Set (CSFLE + Transaktionen ok).
#   mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/pflege_dev?retryWrites=true&w=majority
# Optionale lokale Alternative (Docker, siehe docker-compose.yml):
#   mongodb://localhost:27018/pflege_dev?replicaSet=rs0&directConnection=true
DATABASE_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/pflege_dev?retryWrites=true&w=majority

# Payload-Signing-Secret (von `pnpm run setup` generiert).
PAYLOAD_SECRET=

# Master-Schlüssel für den lokalen Encryption-Port (Dev-Ersatz für KMS/CSFLE).
# In Produktion ersetzt durch Atlas-CSFLE + KMS/Vault.
ENCRYPTION_MASTER_KEY=

# HMAC-Pepper für das WORM-Audit-Log (Dev-Ersatz für Vault Transit).
AUDIT_PEPPER=
AUDIT_PEPPER_VERSION=2026-v1

# Öffentliche App-URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Routing für die Fit-Score-Berechnung.
# haversine = Luftlinien-Heuristik (Standard, keine Infrastruktur nötig).
# osrm      = echtes Straßenrouting über einen OSRM-Server (genauere Fahrzeiten);
#             fällt bei Ausfall/Timeout automatisch auf Haversine zurück.
ROUTING_PROVIDER=haversine
# OSRM-Server-URL (nur bei ROUTING_PROVIDER=osrm). Öffentlicher Demo-Server:
#   https://router.project-osrm.org   (nur Tests/Pilot; für Produktion eigenen Server hosten)
OSRM_BASE_URL=
# OSRM-Profil des Servers (driving | bike | foot — je nach Server-Build).
OSRM_PROFILE=driving
# API-Key, falls der eigene OSRM-Server hinter einem Reverse-Proxy mit
# Schlüsselprüfung steht (Produktion). Muss mit infra/osrm/.env übereinstimmen.
OSRM_API_KEY=

# Geocoding (Adresse → Koordinaten) über Nominatim/OpenStreetMap.
# Öffentlicher Server nur für Pilot/Test (Rate-Limit, Policy); für Produktion
# eigene Instanz hosten. User-Agent muss App + Kontakt nennen.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=PflegeLotse Deutschland/1.0 (+https://deine-domain.de; kontakt@deine-domain.de)

# Später: Payment & KI
# MOLLIE_API_KEY=
# KI-Pflegelotse (Anthropic Claude, serverseitig — Key nie an den Browser).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# SLA / Benachrichtigungen (verbindliche 24h-Rückmeldung)
# E-Mail-Versand über Resend; ohne diese bleibt es beim Konsolen-Log.
RESEND_API_KEY=
EMAIL_FROM=Pflegelotse <info@example.de>
# true = echte E-Mails senden; false/leer = nur Log (Dev/Test).
NOTIFY_ENABLED=false
# Schützt den Cron-Endpoint /api/v1/cron/sla (Authorization: Bearer $CRON_SECRET).
CRON_SECRET=

# Error-Tracking (Sentry). Ohne DSN bleibt Sentry inaktiv.
# DSN aus dem Sentry-Projekt (EU-Region empfohlen: ingest.de.sentry.io).
NEXT_PUBLIC_SENTRY_DSN=
# Nur für den Source-Map-Upload beim Build (optional):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# CSFLE / KMS — echte Feldverschlüsselung der Säule 1.
# true = MongoDB ClientEncryption (KMS + __keyVault); false = lokaler App-Crypto-Adapter.
CSFLE_ENABLED=false
CSFLE_KMS_PROVIDER=local
# local-KMS: 96 Byte Base64. Erzeugen: node -e "console.log(require('crypto').randomBytes(96).toString('base64'))"
CSFLE_LOCAL_MASTER_KEY=
# Für CSFLE_KMS_PROVIDER=aws:
# AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY= / CSFLE_AWS_KEY_REGION= / CSFLE_AWS_KEY_ARN=
